generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  password     String    @db.VarChar(255)
  avatar       String?   @db.VarChar(500)
  role         UserRole  @default(PET_OWNER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  pets         Pet[]
  posts        Post[]
  likes        PostLike[]
  comments     PostComment[]
  reviews      Review[]
  sentMessages     Message[]       @relation("Sender")
  conversations    Conversation[]  @relation("User1")
  conversations2   Conversation[]  @relation("User2")
  notifications    Notification[]
  sessions         RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Pet {
  id        Int       @id @default(autoincrement())
  ownerId   Int       @map("owner_id")
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String    @db.VarChar(100)
  species   String    @db.VarChar(50)
  breed     String?   @db.VarChar(100)
  birthDate DateTime? @map("birth_date")
  weight    Float?
  avatar    String?   @db.VarChar(500)
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  vaccinations    Vaccination[]
  medicalRecords  MedicalRecord[]
  appointments    Appointment[]

  @@map("pets")
}

model Vaccination {
  id          Int       @id @default(autoincrement())
  petId       Int       @map("pet_id")
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  vaccineName String    @map("vaccine_name") @db.VarChar(200)
  dateGiven   DateTime  @map("date_given")
  nextDueDate DateTime? @map("next_due_date")
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("vaccinations")
}

model MedicalRecord {
  id          Int       @id @default(autoincrement())
  petId       Int       @map("pet_id")
  pet         Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  vetId       Int?      @map("vet_id")
  diagnosis   String?   @db.Text
  treatment   String?   @db.Text
  notes       String?   @db.Text
  recordDate  DateTime  @default(now()) @map("record_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  files       MedicalFile[]

  @@map("medical_records")
}

model MedicalFile {
  id        Int      @id @default(autoincrement())
  recordId  Int      @map("record_id")
  record    MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fileName  String   @map("file_name") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.VarChar(500)
  fileType  String   @map("file_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("medical_files")
}

model Shop {
  id          Int       @id @default(autoincrement())
  ownerId     Int       @map("owner_id")
  name        String    @db.VarChar(200)
  description String?   @db.Text
  logo        String?   @db.VarChar(500)
  cover       String?   @db.VarChar(500)
  address     String?   @db.VarChar(300)
  lat         Float?
  lng         Float?
  phone       String?   @db.VarChar(20)
  status      ShopStatus @default(PENDING)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  services    Service[]
  staffs      ShopStaff[]

  @@map("shops")
}

model ShopStaff {
  id      Int    @id @default(autoincrement())
  shopId  Int    @map("shop_id")
  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId  Int    @map("user_id")

  @@unique([shopId, userId])
  @@map("shop_staffs")
}

model Hospital {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(200)
  description String?   @db.Text
  logo        String?   @db.VarChar(500)
  address     String?   @db.VarChar(300)
  lat         Float?
  lng         Float?
  phone       String?   @db.VarChar(20)
  status      ShopStatus @default(PENDING)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  services      Service[]
  veterinarians Veterinarian[]

  @@map("hospitals")
}

model Veterinarian {
  id          Int       @id @default(autoincrement())
  hospitalId  Int       @map("hospital_id")
  hospital    Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  userId      Int?      @map("user_id")
  name        String    @db.VarChar(100)
  specialty   String?   @db.VarChar(200)
  experience  Int?
  avatar      String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("veterinarians")
}

model Service {
  id           Int      @id @default(autoincrement())
  providerType String   @map("provider_type") @db.VarChar(10)
  shopId       Int?     @map("shop_id")
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  hospitalId   Int?     @map("hospital_id")
  hospital     Hospital? @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  price        Decimal? @db.Decimal(10,2)
  duration     Int?     // minutes
  createdAt    DateTime @default(now()) @map("created_at")

  appointments Appointment[]
  images       ServiceImage[]

  @@map("services")
}

model ServiceImage {
  id        Int      @id @default(autoincrement())
  serviceId Int      @map("service_id")
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  imageUrl  String   @map("image_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("service_images")
}

model Appointment {
  id         Int      @id @default(autoincrement())
  petId      Int      @map("pet_id")
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId     Int      @map("user_id")
  serviceId  Int      @map("service_id")
  service    Service  @relation(fields: [serviceId], references: [id])
  vetId      Int?     @map("vet_id")
  hospitalId Int?     @map("hospital_id")
  dateTime   DateTime @map("date_time")
  notes      String?  @db.Text
  status     AppointmentStatus @default(PENDING)
  createdAt  DateTime @default(now()) @map("created_at")

  history     AppointmentHistory[]

  @@map("appointments")
}

model AppointmentHistory {
  id            Int      @id @default(autoincrement())
  appointmentId Int      @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  status        AppointmentStatus
  notes         String?  @db.Text
  changedBy     Int      @map("changed_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("appointment_history")
}

model Post {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  media    PostMedia[]
  likes    PostLike[]
  comments PostComment[]

  @@map("posts")
}

model PostMedia {
  id       Int    @id @default(autoincrement())
  postId   Int    @map("post_id")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaUrl String @map("media_url") @db.VarChar(500)
  mediaType String @map("media_type") @db.VarChar(10) // image, video

  @@map("post_media")
}

model PostLike {
  id     Int  @id @default(autoincrement())
  postId Int  @map("post_id")
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  Int?     @map("parent_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("post_comments")
}

model Review {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerType String   @map("provider_type") @db.VarChar(10)
  providerId   Int      @map("provider_id")
  rating       Int      @db.TinyInt
  comment      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model Conversation {
  id        Int      @id @default(autoincrement())
  user1Id   Int      @map("user1_id")
  user1     User     @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   Int      @map("user2_id")
  user2     User     @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  messages  Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int      @map("sender_id")
  sender         User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  message        String   @db.Text
  messageType    String   @default("text") @map("message_type") @db.VarChar(10)
  mediaUrl       String?  @map("media_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  refId     Int?     @map("ref_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

enum UserRole {
  PET_OWNER
  SHOP_OWNER
  VET
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum ShopStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  APPOINTMENT
  MESSAGE
  SOCIAL
  SYSTEM
  PROMOTION
}

model PartnerRegistration {
  id              Int      @id @default(autoincrement())
  businessType    String   @map("business_type") @db.VarChar(20)
  shopName        String   @map("shop_name") @db.VarChar(200)
  ownerName       String   @map("owner_name") @db.VarChar(100)
  phone           String   @db.VarChar(20)
  email           String   @db.VarChar(100)
  address         String   @db.VarChar(300)
  businessLicense String?  @map("business_license") @db.VarChar(500)
  vetCertificate  String?  @map("vet_certificate") @db.VarChar(500)
  status          String   @default("pending") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("partner_registrations")
}
